---
import Layout from '../layouts/Layout.astro';
---

<Layout title="OpenCan" description="OpenCan is free, open-source customer feedback management. Self-host for free, or use our managed hosting.">

  <!-- Hero -->
  <section class="pt-24 pb-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-blue-50 text-[#2563EB] border border-blue-100 mb-6">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        Open source · AGPL-3.0
      </span>

      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-[#111827] mb-6 leading-tight">
        Collect feedback.<br />Ship what matters.
      </h1>
      <p class="text-xl text-gray-500 mb-10 max-w-2xl mx-auto leading-relaxed">
        OpenCan is free, open-source customer feedback management. Self-host for free, or use our managed hosting.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="https://github.com/sriramgopalan/opencan"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-[#111827] text-white font-medium hover:bg-gray-800 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
        <a
          href="https://demo.opencan.dev"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-[#2563EB] text-white font-medium hover:bg-blue-700 transition-colors"
        >
          Try the demo
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="mt-16">
        <img
          src="/screenshot.png"
          alt="OpenCan feedback board showing posts with voting and status badges"
          class="rounded-xl shadow-2xl border border-gray-200 w-full"
        />
      </div>
    </div>
  </section>

  <!-- Feature: Feedback Boards -->
  <section id="boards" class="py-20 px-4 sm:px-6 lg:px-8 border-t border-gray-100 scroll-mt-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Screenshot left on desktop, top on mobile -->
        <div class="rounded-xl overflow-hidden shadow-2xl ring-1 ring-black/5">
          <!-- Browser chrome -->
          <div class="flex items-center gap-1.5 px-4 h-9 bg-gray-100 border-b border-gray-200 shrink-0">
            <span class="w-3 h-3 rounded-full bg-red-400"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
            <span class="w-3 h-3 rounded-full bg-green-400"></span>
            <span class="flex-1 mx-3 h-5 rounded bg-white border border-gray-200 text-[10px] text-gray-400 flex items-center px-2 overflow-hidden">demo.opencan.dev/boards</span>
          </div>
          <div class="aspect-[16/10] bg-gray-100 overflow-hidden">
            <img
              src="/screenshots/boards.png"
              alt="OpenCan feedback board with posts, voting counts, and status badges"
              class="w-full h-full object-cover object-top"
            />
          </div>
        </div>
        <!-- Text right on desktop -->
        <div>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-blue-50 text-[#2563EB] border border-blue-100 mb-4">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
            </svg>
            Feedback Boards
          </span>
          <h2 class="text-3xl sm:text-4xl font-bold text-[#111827] mb-4 leading-tight">
            Public boards that close the loop
          </h2>
          <p class="text-gray-500 leading-relaxed mb-6">
            Give customers a single place to submit and vote on feature requests. Posts move through Open → Under Review → Planned → In Progress → Shipped — no spreadsheet required. Guest support means anyone can participate without creating an account.
          </p>
          <ul class="space-y-2.5">
            {[
              'Public voting — surface what customers actually want',
              'Post status lifecycle with automatic notifications',
              'Guest posting — no account required to vote',
              'Duplicate ideas surface naturally through upvotes',
            ].map(item => (
              <li class="flex items-center gap-2.5 text-sm text-gray-600">
                <svg class="w-4 h-4 text-[#2563EB] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Public Roadmap (text left / image right on desktop; image top on mobile) -->
  <section id="roadmap" class="py-20 px-4 sm:px-6 lg:px-8 bg-white border-t border-gray-100 scroll-mt-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Text: bottom on mobile (order-2), left on desktop (md:order-1) -->
        <div class="order-2 md:order-1">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-blue-50 text-[#2563EB] border border-blue-100 mb-4">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Public Roadmap
          </span>
          <h2 class="text-3xl sm:text-4xl font-bold text-[#111827] mb-4 leading-tight">
            Show customers exactly where you're headed
          </h2>
          <p class="text-gray-500 leading-relaxed mb-6">
            A shareable <code class="bg-gray-100 px-1.5 py-0.5 rounded text-sm">/roadmap</code> page groups your posts by status — Under Review, Planned, In Progress, and Shipped. Customers always know the state of their requests without emailing you for updates.
          </p>
          <ul class="space-y-2.5">
            {[
              'Status-grouped view: Under Review → Planned → In Progress → Shipped',
              'Shareable link for customers and stakeholders',
              'Always in sync with your boards — no manual updates',
              'No separate roadmap tool needed',
            ].map(item => (
              <li class="flex items-center gap-2.5 text-sm text-gray-600">
                <svg class="w-4 h-4 text-[#2563EB] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <!-- Screenshot: top on mobile (order-1), right on desktop (md:order-2) -->
        <div class="order-1 md:order-2 rounded-xl overflow-hidden shadow-2xl ring-1 ring-black/5">
          <div class="flex items-center gap-1.5 px-4 h-9 bg-gray-100 border-b border-gray-200 shrink-0">
            <span class="w-3 h-3 rounded-full bg-red-400"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
            <span class="w-3 h-3 rounded-full bg-green-400"></span>
            <span class="flex-1 mx-3 h-5 rounded bg-white border border-gray-200 text-[10px] text-gray-400 flex items-center px-2 overflow-hidden">demo.opencan.dev/roadmap</span>
          </div>
          <div class="aspect-[16/10] bg-gray-100 overflow-hidden">
            <img
              src="/screenshots/roadmap.png"
              alt="OpenCan public roadmap grouped by status columns"
              class="w-full h-full object-cover object-top"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Changelog (image left / text right on desktop) -->
  <section id="changelog" class="py-20 px-4 sm:px-6 lg:px-8 border-t border-gray-100 scroll-mt-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Screenshot left on desktop, top on mobile -->
        <div class="rounded-xl overflow-hidden shadow-2xl ring-1 ring-black/5">
          <div class="flex items-center gap-1.5 px-4 h-9 bg-gray-100 border-b border-gray-200 shrink-0">
            <span class="w-3 h-3 rounded-full bg-red-400"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
            <span class="w-3 h-3 rounded-full bg-green-400"></span>
            <span class="flex-1 mx-3 h-5 rounded bg-white border border-gray-200 text-[10px] text-gray-400 flex items-center px-2 overflow-hidden">demo.opencan.dev/changelog</span>
          </div>
          <div class="aspect-[16/10] bg-gray-100 overflow-hidden">
            <img
              src="/screenshots/changelog.png"
              alt="OpenCan changelog with dated release notes linked to shipped posts"
              class="w-full h-full object-cover object-top"
            />
          </div>
        </div>
        <!-- Text right on desktop -->
        <div>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-blue-50 text-[#2563EB] border border-blue-100 mb-4">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
            Changelog
          </span>
          <h2 class="text-3xl sm:text-4xl font-bold text-[#111827] mb-4 leading-tight">
            Turn every release into a moment customers remember
          </h2>
          <p class="text-gray-500 leading-relaxed mb-6">
            Publish dated release notes with Markdown. Link entries to the shipped posts that prompted them, so customers see exactly which requests you addressed. Voters are automatically notified by email when something they upvoted ships.
          </p>
          <ul class="space-y-2.5">
            {[
              'Markdown editor with full formatting support',
              'Link changelog entries to shipped feedback posts',
              'Automatic email notifications to voters on ship',
              'Dated entries with shareable permalink URLs',
            ].map(item => (
              <li class="flex items-center gap-2.5 text-sm text-gray-600">
                <svg class="w-4 h-4 text-[#2563EB] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: In-App Widget (text left / image right on desktop; image top on mobile) -->
  <section id="widget" class="py-20 px-4 sm:px-6 lg:px-8 bg-white border-t border-gray-100 scroll-mt-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Text: bottom on mobile (order-2), left on desktop (md:order-1) -->
        <div class="order-2 md:order-1">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-blue-50 text-[#2563EB] border border-blue-100 mb-4">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            In-App Widget
          </span>
          <h2 class="text-3xl sm:text-4xl font-bold text-[#111827] mb-4 leading-tight">
            Collect feedback without interrupting your users' flow
          </h2>
          <p class="text-gray-500 leading-relaxed mb-6">
            A single <code class="bg-gray-100 px-1.5 py-0.5 rounded text-sm">&lt;script&gt;</code> tag adds a floating feedback button to any page. Supports JWT auto-login so your users never see a second sign-in screen — they're already authenticated from your app.
          </p>
          <ul class="space-y-2.5">
            {[
              'One script tag — no SDK or build step required',
              'JWT auto-login so users never sign in twice',
              'Floating button stays out of the way until needed',
              'Captures page context where feedback is given',
            ].map(item => (
              <li class="flex items-center gap-2.5 text-sm text-gray-600">
                <svg class="w-4 h-4 text-[#2563EB] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <!-- Screenshot: top on mobile (order-1), right on desktop (md:order-2) -->
        <div class="order-1 md:order-2 rounded-xl overflow-hidden shadow-2xl ring-1 ring-black/5">
          <div class="flex items-center gap-1.5 px-4 h-9 bg-gray-100 border-b border-gray-200 shrink-0">
            <span class="w-3 h-3 rounded-full bg-red-400"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
            <span class="w-3 h-3 rounded-full bg-green-400"></span>
            <span class="flex-1 mx-3 h-5 rounded bg-white border border-gray-200 text-[10px] text-gray-400 flex items-center px-2 overflow-hidden">your-app.com/dashboard</span>
          </div>
          <div class="aspect-[16/10] bg-gray-100 overflow-hidden">
            <img
              src="/screenshots/widget.png"
              alt="OpenCan in-app widget floating button and feedback panel"
              class="w-full h-full object-cover object-top"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Also Included -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-white border-t border-gray-100">
    <div class="max-w-5xl mx-auto">
      <p class="text-sm font-medium text-gray-400 uppercase tracking-wide text-center mb-8">Also included</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          {
            icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z',
            title: 'Admin Dashboard',
            desc: 'User management, moderation queue, webhook configuration, and workspace analytics.',
          },
          {
            icon: 'M5 12h14M12 5l7 7-7 7',
            title: 'Self-hosted',
            desc: 'Deploy with Docker Compose in minutes. Your data, your server, AGPL-3.0. No vendor lock-in.',
          },
          {
            icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9',
            title: 'Status-change email notifications',
            desc: 'Voters are automatically emailed when their requested feature moves to a new status.',
          },
          {
            icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            title: 'Full-text search',
            desc: 'Search across all posts and comments on your boards to find and triage duplicates fast.',
          },
          {
            icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
            title: '"My posts" history',
            desc: 'Users can view all the posts they\'ve submitted or voted on from a dedicated history page.',
          },
          {
            icon: 'M13 10V3L4 14h7v7l9-11h-7z',
            title: 'Outbound webhooks',
            desc: 'Fire events to Slack, Linear, or any endpoint when posts are created or their status changes.',
          },
        ].map(({ icon, title, desc }) => (
          <div class="flex items-start gap-3 p-5 rounded-xl bg-[#FAFAFA] border border-gray-100">
            <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-[#111827] mb-0.5">{title}</p>
              <p class="text-xs text-gray-500 leading-relaxed">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 border-t border-gray-100">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-bold text-[#111827] mb-4">How it works</h2>
        <p class="text-gray-500">Up and running in three steps.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">
        <!-- Connector line (desktop only) -->
        <div class="hidden md:block absolute top-8 left-[calc(16.67%+1rem)] right-[calc(16.67%+1rem)] h-px bg-gray-200" aria-hidden="true"></div>

        {[
          {
            step: '1',
            title: 'Create a board',
            body: 'Set up a public feedback board for feature requests, bug reports, or anything else. Configure guest access and post permissions.',
          },
          {
            step: '2',
            title: 'Collect feedback and votes',
            body: 'Customers submit posts and vote on what matters most to them. Duplicate ideas surface naturally through upvotes.',
          },
          {
            step: '3',
            title: 'Close the loop with status updates',
            body: 'Move posts through your workflow — Under Review → Planned → In Progress → Shipped — and keep everyone who voted informed.',
          },
        ].map(({ step, title, body }) => (
          <div class="text-center relative">
            <div class="w-16 h-16 rounded-full bg-[#2563EB] text-white text-xl font-bold flex items-center justify-center mx-auto mb-5 relative z-10">
              {step}
            </div>
            <h3 class="font-semibold text-[#111827] mb-2">{title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Get Notified panel -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-blue-50 border-y border-blue-100">
    <div class="max-w-xl mx-auto text-center">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-white text-[#2563EB] border border-blue-200 mb-6">
        Hosted · Coming Soon
      </span>
      <h2 class="text-3xl font-bold text-[#111827] mb-4">OpenCan Hosted is coming</h2>
      <p class="text-gray-600 mb-8 leading-relaxed">
        Want OpenCan without managing a server? We're building a fully managed hosted plan. Sign up to be first to know — and get an early-supporter discount.
      </p>
      <form id="landing-notify-form" class="flex flex-col sm:flex-row gap-3">
        <input
          id="landing-notify-email"
          type="email"
          required
          placeholder="you@example.com"
          class="flex-1 px-3.5 py-2.5 text-sm rounded-lg border border-blue-200 bg-white text-[#111827] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2563EB] focus:border-transparent transition"
        />
        <button
          type="submit"
          class="px-5 py-2.5 rounded-lg bg-[#2563EB] text-white text-sm font-medium hover:bg-blue-700 transition-colors whitespace-nowrap"
        >
          Notify me
        </button>
