---
import Layout from '../layouts/Layout.astro';
---

<Layout title="OpenCan" description="OpenCan is free, open-source customer feedback management. Self-host for free, or use our managed hosting.">

  <!-- Hero -->
  <section class="pt-24 pb-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-blue-50 text-[#2563EB] border border-blue-100 mb-6">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        Open source · AGPL-3.0
      </span>

      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-[#111827] mb-6 leading-tight">
        Collect feedback.<br />Ship what matters.
      </h1>
      <p class="text-xl text-gray-500 mb-10 max-w-2xl mx-auto leading-relaxed">
        OpenCan is free, open-source customer feedback management. Self-host for free, or use our managed hosting.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="https://github.com/sriramgopalan/opencan"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-[#111827] text-white font-medium hover:bg-gray-800 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
        <a
          href="https://demo.opencan.dev"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-[#2563EB] text-white font-medium hover:bg-blue-700 transition-colors"
        >
          Try the demo
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Screenshot placeholder -->
      <div class="mt-16 rounded-xl border border-gray-200 bg-gray-100 aspect-video flex items-center justify-center shadow-sm">
        <div class="text-center">
          <div class="w-10 h-10 rounded-full bg-gray-200 flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <p class="text-sm text-gray-400 font-medium">Screenshot coming soon</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-white border-y border-gray-100">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-bold text-[#111827] mb-4">Everything you need to close the loop</h2>
        <p class="text-gray-500 max-w-xl mx-auto">One tool for collecting, prioritizing, and communicating feature requests — without paying per seat.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="p-6 rounded-xl border border-gray-200 bg-[#FAFAFA] hover:border-gray-300 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-[#111827] mb-2">Feedback Boards</h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            Public boards with voting, post status management, and guest support. Move posts through Open → Planned → Shipped without a spreadsheet.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="p-6 rounded-xl border border-gray-200 bg-[#FAFAFA] hover:border-gray-300 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-[#111827] mb-2">Admin Dashboard</h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            User management, moderation queue, and workspace analytics. See what your customers actually want, not just what's loudest.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="p-6 rounded-xl border border-gray-200 bg-[#FAFAFA] hover:border-gray-300 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-[#111827] mb-2">Self-hosted</h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            Deploy with Docker Compose in minutes. Your data, your server, AGPL-3.0. No vendor lock-in, no per-seat pricing, no surprises.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-bold text-[#111827] mb-4">How it works</h2>
        <p class="text-gray-500">Up and running in three steps.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">
        <!-- Connector line (desktop only) -->
        <div class="hidden md:block absolute top-8 left-[calc(16.67%+1rem)] right-[calc(16.67%+1rem)] h-px bg-gray-200" aria-hidden="true"></div>

        {[
          {
            step: '1',
            title: 'Create a board',
            body: 'Set up a public feedback board for feature requests, bug reports, or anything else. Configure guest access and post permissions.',
          },
          {
            step: '2',
            title: 'Collect feedback and votes',
            body: 'Customers submit posts and vote on what matters most to them. Duplicate ideas surface naturally through upvotes.',
          },
          {
            step: '3',
            title: 'Close the loop with status updates',
            body: 'Move posts through your workflow — Under Review → Planned → In Progress → Shipped — and keep everyone who voted informed.',
          },
        ].map(({ step, title, body }) => (
          <div class="text-center relative">
            <div class="w-16 h-16 rounded-full bg-[#2563EB] text-white text-xl font-bold flex items-center justify-center mx-auto mb-5 relative z-10">
              {step}
            </div>
            <h3 class="font-semibold text-[#111827] mb-2">{title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Open source CTA -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-[#111827]">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium bg-white/10 text-gray-300 border border-white/20 mb-6">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        AGPL-3.0 · Free forever
      </div>

      <h2 class="text-4xl font-bold text-white mb-4">Free forever. Self-host with Docker Compose.</h2>
      <p class="text-gray-400 text-lg mb-10 leading-relaxed">
        No seat pricing. No usage limits. No data leaving your infrastructure. One command to deploy the full stack.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-10">
        <a
          href="https://github.com/sriramgopalan/opencan"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-white text-[#111827] font-medium hover:bg-gray-100 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
        <a
          href="/docs/self-hosting"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg border border-white/20 text-white font-medium hover:bg-white/10 transition-colors"
        >
          Self-hosting guide
        </a>
      </div>

      <div class="flex items-center justify-center gap-4 text-sm">
        <a
          href="https://www.gnu.org/licenses/agpl-3.0"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded bg-blue-900/50 text-blue-300 border border-blue-800 font-mono text-xs hover:bg-blue-900 transition-colors"
        >
          License: AGPL-3.0
        </a>
      </div>
    </div>
  </section>

</Layout>
