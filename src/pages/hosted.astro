---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hosted" description="OpenCan Hosted is a fully managed hosted plan coming soon. Zero ops, automatic updates, reasonable pricing. Join the waitlist.">

  <section class="pt-24 pb-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto text-center">

      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-blue-50 text-[#2563EB] border border-blue-100 mb-6">
        Coming Soon
      </span>

      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-[#111827] mb-6 leading-tight">
        OpenCan Hosted
      </h1>
      <p class="text-xl text-gray-500 mb-16 max-w-xl mx-auto leading-relaxed">
        All the power of OpenCan — feedback boards, roadmap, changelog, and widget — without a server to manage. We handle deployments, backups, and updates.
      </p>

      <!-- What you get -->
      <div class="grid sm:grid-cols-3 gap-4 mb-16 text-left">
        <div class="bg-white rounded-xl border border-gray-200 p-5">
          <div class="w-9 h-9 rounded-lg bg-blue-50 flex items-center justify-center mb-3">
            <svg class="w-4 h-4 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-[#111827] mb-1">Zero ops</h3>
          <p class="text-sm text-gray-500 leading-relaxed">No server to provision or maintain. We run the infrastructure.</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-5">
          <div class="w-9 h-9 rounded-lg bg-blue-50 flex items-center justify-center mb-3">
            <svg class="w-4 h-4 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-[#111827] mb-1">Automatic updates</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Always on the latest version. No manual deploys, no migrations to run.</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-5">
          <div class="w-9 h-9 rounded-lg bg-blue-50 flex items-center justify-center mb-3">
            <svg class="w-4 h-4 text-[#2563EB]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-[#111827] mb-1">Managed backups</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Daily backups included. Your data is safe even if you never think about it.</p>
        </div>
      </div>

      <!-- Waitlist form -->
      <div class="bg-gray-50 border border-gray-200 rounded-2xl p-8 sm:p-10">
        <h2 class="text-2xl font-bold text-[#111827] mb-2">Get notified when it's ready</h2>
        <p class="text-gray-500 text-sm mb-6 leading-relaxed">
          We're pricing it to be genuinely reasonable — no per-seat nonsense. Early waitlist members get a discount at launch.
        </p>

        <form id="hosted-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input
            id="hosted-email"
            type="email"
            required
            placeholder="you@example.com"
            class="flex-1 px-3.5 py-2.5 text-sm rounded-lg border border-gray-200 bg-white text-[#111827] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2563EB] focus:border-transparent transition"
          />
          <button
            type="submit"
            class="px-5 py-2.5 rounded-lg bg-[#2563EB] text-white text-sm font-medium hover:bg-blue-700 transition-colors whitespace-nowrap"
          >
            Join the waitlist
          </button>
        </form>

        <div id="hosted-success" class="hidden mt-4 flex items-center justify-center gap-2 text-sm text-green-700">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
          You're on the list. We'll reach out when the hosted plan is ready.
        </div>

        <p class="text-xs text-gray-400 mt-4">No spam. One email when it launches.</p>
      </div>

      <!-- For those who can't wait -->
      <p class="mt-10 text-sm text-gray-500">
        Can't wait?
        <a href="/docs/getting-started" class="text-[#2563EB] hover:underline">
          Self-host in minutes with Docker Compose →
        </a>
      </p>

    </div>
  </section>

  <script>
    const form = document.getElementById('hosted-form') as HTMLFormElement | null;
    const success = document.getElementById('hosted-success');
    // Wire this up to your email collection service (Resend, Formspree, etc.)
    form?.addEventListener('submit', e => {
      e.preventDefault();
      form.classList.add('hidden');
      success?.classList.remove('hidden');
    });
  </script>

</Layout>
