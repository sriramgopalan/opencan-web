---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const navItems = [
  { label: 'Overview', href: '/docs' },
  { label: 'Getting Started', href: '/docs/getting-started' },
  { label: 'Self-hosting Guide', href: '/docs/self-hosting' },
  { label: 'Environment Variables', href: '/docs/environment-variables' },
  {
    label: 'Contributing',
    href: 'https://github.com/sriramgopalan/opencan',
    external: true,
  },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '');
---

<Layout title={title} description={description}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex gap-12">
      <!-- Sidebar -->
      <aside class="w-52 shrink-0 hidden md:block">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3 px-3">
          Documentation
        </p>
        <nav class="space-y-0.5">
          {
            navItems.map((item) => {
              const isActive = currentPath === item.href.replace(/\/$/, '');
              return (
                <a
                  href={item.href}
                  target={item.external ? '_blank' : undefined}
                  rel={item.external ? 'noopener noreferrer' : undefined}
                  class={[
                    'flex items-center gap-1.5 px-3 py-2 text-sm rounded-md transition-colors',
                    isActive
                      ? 'bg-blue-50 text-[#2563EB] font-medium'
                      : 'text-gray-600 hover:text-[#111827] hover:bg-gray-100',
                  ].join(' ')}
                >
                  {item.label}
                  {item.external && (
                    <svg
                      class="w-3 h-3 opacity-50"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                  )}
                </a>
              );
            })
          }
        </nav>
      </aside>

      <!-- Mobile nav -->
      <div class="md:hidden mb-6 w-full">
        <div class="flex gap-2 flex-wrap">
          {
            navItems.map((item) => {
              const isActive = currentPath === item.href.replace(/\/$/, '');
              return (
                <a
                  href={item.href}
                  class={[
                    'px-3 py-1.5 text-sm rounded-full border transition-colors',
                    isActive
                      ? 'border-[#2563EB] bg-blue-50 text-[#2563EB]'
                      : 'border-gray-200 text-gray-600 hover:border-gray-400',
                  ].join(' ')}
                >
                  {item.label}
                </a>
              );
            })
          }
        </div>
      </div>

      <!-- Content -->
      <article class="flex-1 min-w-0 prose">
        <slot />
      </article>
    </div>
  </div>
</Layout>
